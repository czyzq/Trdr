{
  "strategies": [
    {
      "id": "btc_v2_core",
      "name": "BTC v2 Core 5m",
      "symbol": "BTC",
      "timeframe": "5m",
      "enabled": true,
      "trade_direction": "long_only",
      "score": {
        "min_score": 0.5,
        "indicators": [
          {
            "name": "RSI",
            "weight": 2.0,
            "normalized_range": [
              -1,
              1
            ]
          },
          {
            "name": "MACD",
            "weight": 0.0,
            "normalized_range": [
              -1,
              1
            ]
          },
          {
            "name": "MOMENTUM",
            "weight": 2.0,
            "normalized_range": [
              -1,
              1
            ]
          },
          {
            "name": "ADX",
            "weight": 0.0,
            "normalized_range": [
              -1,
              1
            ]
          }
        ]
      },
      "filters": {
        "volume": {
          "enabled": true,
          "lookback_bars": 20,
          "min_ratio_to_average": 0.75
        },
        "position_already_open": {
          "enabled": true
        },
        "symbol_enabled_flag": {
          "enabled": true,
          "key_pattern": "TRADE_ENABLED_{SYMBOL}"
        },
        "htf_trend": {
          "enabled": true,
          "indicator": "RSI",
          "htf_timeframe": "30m",
          "source": "close",
          "use_closed_candles_only": true,
          "long_condition": {
            "operator": ">",
            "value": 50
          },
          "short_condition": null
        },
        "volatility": {
          "enabled": true,
          "max_atr_percent": 3.0
        },
        "vix": {
          "enabled": false,
          "max_vix": 30
        },
        "vix_enabled": false
      },
      "risk": {
        "risk_per_trade_pct": 2.0,
        "max_total_risk_pct": 2.0,
        "leverage": 20,
        "max_notional_exposure_multiple": 1.0
      },
      "position_sizing": {
        "formula": "size = (balance * (risk_per_trade_pct/100) * leverage) / price",
        "rounding": {
          "mode": "floor",
          "step": 0.0001
        }
      },
      "exits": {
        "stop_loss": {
          "type": "percent_from_entry",
          "value": -2.0
        },
        "take_profit": {
          "type": "percent_from_entry",
          "value": 5.0
        },
        "trailing_stop": {
          "enabled": false
        },
        "dynamic_tp": {
          "enabled": true,
          "htf_indicator": "RSI",
          "htf_timeframe": "30m",
          "use_closed_candles_only": true,
          "rules": [
            {
              "condition": {
                "operator": ">",
                "value": 65
              },
              "tp_percent": 3.0
            },
            {
              "condition": {
                "operator": "<",
                "value": 40
              },
              "tp_percent": 7.0
            }
          ],
          "default_tp_percent": 5.0
        }
      }
    },
