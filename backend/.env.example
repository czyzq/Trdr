# Alpha Vantage API key (free: 25 req/day at alphavantage.co/support/#api-key)
# Used for both price data (quotes, candles) and news sentiment
ALPHA_VANTAGE_API_KEY=your_key_here

# MongoDB connection string (free tier at mongodb.com/atlas)
# Without this, all data is in-memory and lost on restart
MONGO_URI=mongodb+srv://user:pass@cluster.mongodb.net/
MONGO_DB=cfd_trading_bot

# Broker selection: "sim" (default) or "ibkr"
BROKER_TYPE=sim

# Interactive Brokers settings (only needed if BROKER_TYPE=ibkr)
# Requires IB Gateway or TWS running with API enabled
# IBKR_HOST=127.0.0.1
# IBKR_PORT=7497          # 7497=paper trading, 7496=live
# IBKR_CLIENT_ID=1
